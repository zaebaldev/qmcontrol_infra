{
    "version": 3,
    "port": 8080,
    "extra_config": {
        "github_com/devopsfaith/krakend-gologging": {
            "level": "INFO",
            "prefix": "[KRAKEND]",
            "stdout": true
        }
    },
    "endpoints": [
        {
            "endpoint": "/auth/quarry_admin/login",
            "method": "POST",
            "output_encoding": "no-op",
            "headers_to_pass": [
                "*"
            ],
            "backend": [
                {
                    "host": [
                        "http://auth_service:8000"
                    ],
                    "url_pattern": "/api/v1/auth/quarry_admin/login",
                    "encoding": "no-op"
                }
            ]
        },
        {
            "endpoint": "/auth/company_admin/login",
            "method": "POST",
            "output_encoding": "no-op",
            "headers_to_pass": [
                "*"
            ],
            "backend": [
                {
                    "host": [
                        "http://localhost:8000"
                    ],
                    "url_pattern": "/api/v1/auth/company_admin/login",
                    "encoding": "no-op"
                }
            ]
        },
        {
            "endpoint": "/integrations/didox/token",
            "method": "POST",
            "headers_to_pass": [
                "Authorization"
            ],
            "backend": [
                {
                    "host": [
                        "http://localhost:8001"
                    ],
                    "url_pattern": "/api/v1/didox/auth/token"
                }
            ]
        },
        {
            "endpoint": "/api/companies",
            "method": "GET",
            "backend": [
                {
                    "host": [
                        "http://localhost:8002"
                    ],
                    "url_pattern": "/api/v1/companies"
                }
            ],
            "extra_config": {
                "auth/validator": {
                    "alg": "RS256",
                    "roles_key": "role",
                    "roles": [
                        "quarry_admin",
                        "admin"
                    ],
                    "jwk_url": "http://localhost:8000/api/v1/.well-known/jwks.json",
                    "cache": true,
                    "disable_jwk_security": true
                }
            }
        }
    ]
}